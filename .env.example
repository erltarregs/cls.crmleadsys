# ── Application ────────────────────────────────────────
APP_NAME="System"
APP_ENV=development
DEBUG=True

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/DB_NAME
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@localhost:5432/DB_NAME

# ── Security ───────────────────────────────────────────
SECRET_KEY= # generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── File Uploads ───────────────────────────────────────
UPLOAD_DIR=uploads/photos
MAX_FILE_SIZE_MB=5
